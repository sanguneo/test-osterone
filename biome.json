{
	"$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
	"vcs": { "enabled": false, "clientKind": "git", "useIgnoreFile": true },
	"files": { "includes": ["src/**", "test/**", "examples/**", "!src/app/studio/web"] },
	"formatter": { "enabled": true, "indentStyle": "tab", "lineWidth": 120 },
	"javascript": { "formatter": { "quoteStyle": "double" } },
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended"
		}
	}
}
