{
	"name": "test-osterone",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"description": "test-osterone — AI web test-automation (deterministic verdicts, sheet-driven cases)",
	"module": "src/index.ts",
	"bin": {
		"test-osterone": "src/cli.ts"
	},
	"scripts": {
		"postinstall": "playwright install chromium || true",
		"setup": "playwright install chromium",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"fmt": "biome format --write .",
		"test": "bun test",
		"build": "bun build src/cli.ts --compile --outfile dist/test-osterone",
		"demo": "node --experimental-transform-types examples/demo/run-demo.ts",
		"run:live": "node --experimental-transform-types examples/demo/run-demo.ts",
		"studio": "bun run studio:build && node --experimental-transform-types src/app/studio/server.ts",
		"studio:build": "cd src/app/studio/web && vite build",
		"studio:webcheck": "bun node_modules/typescript/bin/tsc -p src/app/studio/web/tsconfig.json",
		"doctor": "npx react-doctor@latest"
	},
	"engines": {
		"bun": ">=1.3.0",
		"node": ">=22.7"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.2",
		"@types/bun": "^1.3.14",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"react-doctor": "^0.8.1",
		"react-grab": "^0.1.48",
		"react-scan": "^0.5.7",
		"typescript": "^7.0.2",
		"vite": "^8.1.5"
	},
	"dependencies": {
		"playwright": "^1.61.1",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"xlsx": "^0.18.5"
	}
}
